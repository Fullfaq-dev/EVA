# Supabase
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Telegram Bot
VITE_TELEGRAM_BOT_TOKEN=your-bot-token

# n8n Webhooks
VITE_N8N_FOOD_WEBHOOK_URL=https://your-n8n-instance/webhook/food
VITE_N8N_FOOD_WEBHOOK_TEST_URL=https://your-n8n-instance/webhook-test/food
VITE_N8N_ANALYSIS_WEBHOOK_URL=https://your-n8n-instance/webhook/medical-analysis
VITE_N8N_ANALYSIS_WEBHOOK_TEST_URL=https://your-n8n-instance/webhook-test/medical-analysis

# Webhook Security (optional)
VITE_N8N_WEBHOOK_SECRET=your-webhook-secret

# Robokassa Payment Integration
# MerchantLogin — your shop login in Robokassa personal cabinet
VITE_ROBOKASSA_MERCHANT_LOGIN=your-merchant-login
# Password #1 — from Robokassa shop settings (Technical Settings → Passwords)
VITE_ROBOKASSA_PASSWORD1=your-password1
# Set to "1" for test payments, "0" for real payments
VITE_ROBOKASSA_IS_TEST=1

# Password #2 — used SERVER-SIDE only (Supabase Edge Function secret, never use VITE_ prefix!)
# Set it via: supabase secrets set ROBOKASSA_PASSWORD2=your-password2
# ROBOKASSA_PASSWORD2=your-password2
